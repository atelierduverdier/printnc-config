O<toolchange> sub

; =====================================================================
; PARAMÈTRES
; =====================================================================
#<probe_x>      = -50.0
#<probe_y>      = 60.0
#<search_feed>  = 400
#<latch_feed>   = 25
#<dist_palpeur_table> = 50.384

; =====================================================================
; SÉCURITÉ + CHANGEMENT D'OUTIL
; =====================================================================
G90

; Annule toute compensation avant le changement outil
G49

; Remontée machine
G53 G0 Z0

; Changement outil
M6

; On annule ENCORE toute compensation pour être brut de machine
G49

; Position sécurisée
G53 G0 Z0
G53 G0 X#<probe_x> Y#<probe_y>

; =====================================================================
; PALPAGE OUTIL
; =====================================================================
M70                         ; Sauvegarde état modal
G91                         ; Mode relatif pour la descente

G38.2 Z-140 F#<search_feed> ; Premier palpage rapide
G0 Z2.0                     ; Remontée
G38.2 Z-5.0 F#<latch_feed>  ; Second palpage lent

G90                         ; Retour absolu
#<touch_z> = #5063          ; Capture position machine (SANS CROCHETS)

(DEBUG, touch_z = [#<touch_z>])
M71                         ; Restore modal

; =====================================================================
; CALCUL OFFSETS
; =====================================================================

O100 IF [#1001 EQ 0]

    ; ================================================================
    ; MODE NORMAL
    ; ================================================================

    O101 IF [#1000 EQ 0]
        ; ------------------------------------------------------------
        ; PREMIER OUTIL = OUTIL DE RÉFÉRENCE
        ; ------------------------------------------------------------
        #1000 = #<touch_z>  ; Sauvegarde position machine de référence

        (DEBUG, REF TOOL TOUCH = [#1000])

        G10 L1 P#5400 Z0    ; Offset outil de référence = 0
        G10 L20 P1 Z#<dist_palpeur_table> ; Définition automatique du zéro table

        (MSG, Premier outil reference T[#5400])

    O101 ELSE
        ; ------------------------------------------------------------
        ; OUTILS SUIVANTS (Ex: Ton T6 enfoncé)
        ; ------------------------------------------------------------
        ; FORMULE : TOUCH_Z - REF pour générer l'offset négatif attendu par G43
        #<tool_offset> = [#<touch_z> - #1000]

        (DEBUG, REF = [#1000])
        (DEBUG, TOUCH = [#<touch_z>])
        (DEBUG, OFFSET = [#<tool_offset>])

        G10 L1 P#5400 Z#<tool_offset> ; Écriture de l'offset négatif dans la table

        (MSG, Offset outil T[#5400] calcule)
    O101 ENDIF

O100 ELSE

    ; ================================================================
    ; MODE ALTERNATIF
    ; ================================================================

    O102 IF [#1000 EQ 0]
        #1000 = #<touch_z>
        G10 L1 P#5400 Z0
        (DEBUG, REF TOOL TOUCH = [#1000])
    O102 ELSE
        ; Formule identique ici pour le mode alternatif
        #<tool_offset> = [#<touch_z> - #1000]

        (DEBUG, REF = [#1000])
        (DEBUG, TOUCH = [#<touch_z>])
        (DEBUG, OFFSET = [#<tool_offset>])

        G10 L1 P#5400 Z#<tool_offset>
    O102 ENDIF

O100 ENDIF

; =====================================================================
; ACTIVATION OFFSET + RETOUR
; =====================================================================
G53 G0 Z0                   ; Remontée maximale AVANT activation G43
G43 H#5400                  ; Activation de la compensation de longueur d'outil

(DEBUG, G43 ACTIVE H[#5400])

G0 X#5420 Y#5421            ; Retour au-dessus de la pièce en X/Y

(MSG, Toolchange T[#5400] termine)

O<toolchange> endsub
M2
